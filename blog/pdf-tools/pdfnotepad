    <div id="footer-placeholder"></div>

    <script>
        function loadMoreContent() {
            document.getElementById('hidden-content').classList.remove('content-hidden');
            event.target.style.display = 'none';
        }

        document.addEventListener('DOMContentLoaded', () => {
            
            fetch('')')
                .then(response => {
                    if (!response.ok) throw new Error('Header load failed');
                    return response.text();
                })
                .then(data => {
                    const headerPlaceholder = document.getElementById('header-placeholder');
                    headerPlaceholder.innerHTML = data;
                    
                    const scripts = headerPlaceholder.getElementsByTagName('script');
                    for (let i = 0; i < scripts.length; i++) {
                        const newScript = document.createElement('script');
                        if (scripts[i].src) {
                            newScript.src = scripts[i].src;
                        } else {
                            newScript.innerHTML = scripts[i].innerHTML;
                        }
                        document.body.appendChild(newScript);
                    }

                    const toggleBtn = headerPlaceholder.querySelector('.navbar-toggler, .menu-toggle, .hamburger, [data-toggle="collapse"], button');
                    const navMenu = headerPlaceholder.querySelector('.nav-links, .navbar-collapse, .nav-menu, ul');
                    
                    if (toggleBtn && navMenu) {
                        toggleBtn.addEventListener('click', (e) => {
                            e.preventDefault();
                            navMenu.classList.toggle('force-mobile-show');
                        });
                    }
                })
                .catch(error => console.error('Error fetching header:', error));

            fetch('')')
                .then(response => {
                    if (!response.ok) throw new Error('Footer load failed');
                    return response.text();
                })
                .then(data => {
                    document.getElementById('footer-placeholder').innerHTML = data;
                })
                .catch(error => console.error('Error fetching footer:', error));

            fetch('')')
                .then(response => {
                    if (!response.ok) throw new Error('Blog index load failed');
                    return response.text();
                })
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    
                    let fetchedCards = Array.from(doc.querySelectorAll('.grid-cards .card, article.card, .blog-card, .blog-card-minimal'));
                    
                    if (fetchedCards.length > 0) {
                        const blogContainer = document.getElementById('dynamic-blog-container');
                        blogContainer.innerHTML = '';

                        for (let i = fetchedCards.length - 1; i > 0; i--) {
                            const j = Math.floor(Math.random() * (i + 1));
                            [fetchedCards[i], fetchedCards[j]] = [fetchedCards[j], fetchedCards[i]];
                        }

                        const random3Blogs = fetchedCards.slice(0, 3);
                        
                        random3Blogs.forEach(card => {
                            const imgElement = card.querySelector('img');
                            const headingElement = card.querySelector('h1, h2, h3, h4, h5, h6');
                            const linkElement = card.tagName.toLowerCase() === 'a' ? card : card.querySelector('a');

                            if (imgElement && headingElement) {
                                const newCard = document.createElement('a');
                                newCard.className = 'blog-card-minimal';
                                
                                let href = linkElement ? linkElement.getAttribute('href') : '#';
                                if (href && !href.startsWith('http') && !href.startsWith('//')) {
                                    href = new URL(href, 'https://jkmedit.in/blog/').href;
                                }
                                newCard.href = href;

                                let imgSrc = imgElement.getAttribute('src');
                                if (imgSrc && !imgSrc.startsWith('http') && !imgSrc.startsWith('//')) {
                                    imgSrc = new URL(imgSrc, 'https://jkmedit.in/blog/').href;
                                }

                                const altText = imgElement.getAttribute('alt') || headingElement.innerText;

                                newCard.innerHTML = `
                                    <img src="${imgSrc}" alt="${altText}">
                                    <h4>${headingElement.innerText}</h4>
                                `;

                                blogContainer.appendChild(newCard);
                            }
                        });
                    }
                })
                .catch(error => console.log('Using fallback blogs due to fetch error:', error));

            // FAQ Accordion Logic
            const faqItems = document.querySelectorAll('.faq-item');
            faqItems.forEach(item => {
                const button = item.querySelector('.faq-question');
                button.addEventListener('click', () => {
                    const isActive = item.classList.contains('active');
                    
                    faqItems.forEach(faq => {
                        faq.classList.remove('active');
                        faq.querySelector('.faq-icon').textContent = '+';
                    });
                    
                    if (!isActive) {
                        item.classList.add('active');
                        item.querySelector('.faq-icon').textContent = '×';
                    }
                });
            });
        });
    </script>
