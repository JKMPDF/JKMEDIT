    <div id="footer-placeholder"></div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            fetch('')').then(r => r.text()).then(d => { 
                document.getElementById('header-placeholder').innerHTML = d; 
                const m = document.getElementById('mobileToggle'), n = document.getElementById('navMenu');
                if(m && n) m.onclick = () => { n.classList.toggle('active'); m.innerHTML = n.classList.contains('active') ? '&#10005;' : '&#9776;'; };
            });
            fetch('')').then(r => r.text()).then(d => { document.getElementById('footer-placeholder').innerHTML = d; });
            
            document.querySelectorAll('a').forEach(link => {
                const linkUrl = link.getAttribute('href');
                if (linkUrl && !linkUrl.startsWith('#') && !linkUrl.startsWith('mailto:') && !linkUrl.startsWith('javascript:')) {
                    const isInternalLink = (new URL(linkUrl, window.location.href)).origin === window.location.origin;
                    if (isInternalLink && !link.target) {
                        link.addEventListener('click', function(e) {
                            e.preventDefault(); document.body.classList.add('fade-out');
                            setTimeout(() => { window.location.href = this.href; }, 400);
                        });
                    }
                }
            });
        });

        const dropzone = document.getElementById('dropzone');
        const fileInput = document.getElementById('file-input');
        const uploadStage = document.getElementById('upload-stage');
        const editorStage = document.getElementById('editor-stage');
        const imgPreview = document.getElementById('image-preview');
        
        const widthInput = document.getElementById('input-width');
        const heightInput = document.getElementById('input-height');
        const scaleRange = document.getElementById('scale-range');
        const scaleVal = document.getElementById('scale-val');
        const lockBtn = document.getElementById('lock-btn');
        const formatSelect = document.getElementById('format-select');
        const qualityRange = document.getElementById('quality-range');
        const qualityVal = document.getElementById('quality-val');

        let originalWidth = 0;
        let originalHeight = 0;
        let aspectRatio = 0;
        let isLocked = true;
        let fileName = "image";

        dropzone.onclick = () => fileInput.click();
        dropzone.ondragover = (e) => { e.preventDefault(); dropzone.style.backgroundColor = '#f0f7ff'; dropzone.style.borderColor = 'var(--primary-color)'; };
        dropzone.ondragleave = () => { dropzone.style.backgroundColor = 'var(--surface-color)'; dropzone.style.borderColor = '#ccc'; };
        dropzone.ondrop = (e) => { e.preventDefault(); dropzone.style.backgroundColor = 'var(--surface-color)'; handleFile(e.dataTransfer.files[0]); };
        fileInput.onchange = (e) => handleFile(e.target.files[0]);

        function handleFile(file) {
            if (!file || !file.type.startsWith('image/')) return alert("Please upload a valid image.");
            
            fileName = file.name.substring(0, file.name.lastIndexOf('.'));
            document.getElementById('orig-size').innerText = (file.size / 1024).toFixed(1) + ' KB';

            const reader = new FileReader();
            reader.onload = (e) => {
                imgPreview.src = e.target.result;
                imgPreview.onload = () => {
                    originalWidth = imgPreview.naturalWidth;
                    originalHeight = imgPreview.naturalHeight;
                    aspectRatio = originalWidth / originalHeight;

                    widthInput.value = originalWidth;
                    heightInput.value = originalHeight;
                    document.getElementById('orig-dims').innerText = `${originalWidth} x ${originalHeight}`;

                    if (file.type === 'image/png') formatSelect.value = 'image/png';
                    else if (file.type === 'image/webp') formatSelect.value = 'image/webp';
                    else formatSelect.value = 'image/jpeg';

                    uploadStage.classList.add('hidden');
                    editorStage.classList.remove('hidden');
                };
            };
            reader.readAsDataURL(file);
        }

        function toggleLock() {
            isLocked = !isLocked;
            lockBtn.classList.toggle('active', isLocked);
            lockBtn.innerHTML = isLocked ? '<i class="fa-solid fa-link"></i>' : '<i class="fa-solid fa-link-slash"></i>';
            if(isLocked) {
                heightInput.value = Math.round(widthInput.value / aspectRatio);
            }
        }

        widthInput.addEventListener('input', () => {
            if (isLocked && widthInput.value) {
                heightInput.value = Math.round(widthInput.value / aspectRatio);
            }
            updateScaleSlider();
        });

        heightInput.addEventListener('input', () => {
            if (isLocked && heightInput.value) {
                widthInput.value = Math.round(heightInput.value * aspectRatio);
            }
            updateScaleSlider();
        });

        scaleRange.addEventListener('input', () => {
            const percent = scaleRange.value;
            scaleVal.innerText = percent + '%';
            
            const newW = Math.round(originalWidth * (percent / 100));
            const newH = Math.round(originalHeight * (percent / 100));
            
            widthInput.value = newW;
            heightInput.value = newH;
        });

        function updateScaleSlider() {
            const w = parseInt(widthInput.value);
            const percent = Math.round((w / originalWidth) * 100);
            if(percent >= 10 && percent <= 200) {
                scaleRange.value = percent;
                scaleVal.innerText = percent + '%';
            } else {
                scaleVal.innerText = 'Custom';
            }
        }

        qualityRange.addEventListener('input', () => {
            qualityVal.innerText = qualityRange.value + '%';
        });

        function resizeAndDownload() {
            const newW = parseInt(widthInput.value);
            const newH = parseInt(heightInput.value);
            const format = formatSelect.value;
            const quality = parseInt(qualityRange.value) / 100;

            if (!newW || !newH) return alert("Invalid dimensions.");

            const canvas = document.createElement('canvas');
            canvas.width = newW;
            canvas.height = newH;
            const ctx = canvas.getContext('2d');

            ctx.imageSmoothingEnabled = true;
            ctx.imageSmoothingQuality = 'high';

            if (format === 'image/jpeg') {
                ctx.fillStyle = '#ffffff';
                ctx.fillRect(0, 0, newW, newH);
            }

            ctx.drawImage(imgPreview, 0, 0, newW, newH);

            let ext = 'jpg';
            if (format === 'image/png') ext = 'png';
            if (format === 'image/webp') ext = 'webp';

            canvas.toBlob((blob) => {
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `${fileName}_resized.${ext}`;
                document.body.appendChild(a);
                a.click();
                setTimeout(() => {
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                }, 100);
            }, format, quality);
        }
    </script>
