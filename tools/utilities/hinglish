            fetch('')').then(r => r.text()).then(d => { document.getElementById('footer-placeholder').innerHTML = d; });

            document.querySelectorAll('a').forEach(link => {
                const linkUrl = link.getAttribute('href');
                if (linkUrl && !linkUrl.startsWith('#') && !linkUrl.startsWith('mailto:') && !linkUrl.startsWith('javascript:')) {
                    const isInternalLink = (new URL(linkUrl, window.location.href)).origin === window.location.origin;
                    if (isInternalLink && !link.target) {
                        link.addEventListener('click', function(e) {
                            e.preventDefault(); document.body.classList.add('fade-out');
                            setTimeout(() => { window.location.href = this.href; }, 400);
                        });
                    }
                }
            });

            const charMap = {
                'अ': 'a', 'आ': 'aa', 'इ': 'i', 'ई': 'ee', 'उ': 'u', 'ऊ': 'oo', 'ऋ': 'ri', 'ए': 'e', 'ऐ': 'ai', 'ओ': 'o', 'औ': 'au',
                'क': 'k', 'ख': 'kh', 'ग': 'g', 'घ': 'gh', 'ङ': 'n',
                'च': 'ch', 'छ': 'chh', 'ज': 'j', 'झ': 'jh', 'ञ': 'n',
                'ट': 't', 'ठ': 'th', 'ड': 'd', 'ढ': 'dh', 'ण': 'n',
                'त': 't', 'थ': 'th', 'द': 'd', 'ध': 'dh', 'न': 'n',
                'प': 'p', 'फ': 'ph', 'ब': 'b', 'भ': 'bh', 'म': 'm',
                'य': 'y', 'र': 'r', 'ल': 'l', 'व': 'v', 'श': 'sh', 'ष': 'sh', 'स': 's', 'ह': 'h',
                'ा': 'a', 'ि': 'i', 'ी': 'ee', 'ु': 'u', 'ू': 'oo', 'ृ': 'ri', 'े': 'e', 'ै': 'ai', 'ो': 'o', 'ौ': 'au', 'ं': 'n', 'ः': 'ah'
            };

            const input = document.getElementById('hindiInput');
            const output = document.getElementById('hinglishOutput');
            const copyBtn = document.getElementById('copyBtn');
            const status = document.getElementById('copyStatus');

            function convert(text) {
                let result = "";
                const isSymbolOrSpace = /[\s,.\/#!$%\^&\*;:{}=\-_`~()।?!]/;

                for (let i = 0; i < text.length; i++) {
                    let char = text[i];
                    let nextChar = text[i + 1];

                    if (char === '्') continue; 

                    if (charMap[char]) {
                        let mappedValue = charMap[char];

                        if (char === 'ी' || char === 'ई') {
                            const isEndOfWord = !nextChar || isSymbolOrSpace.test(nextChar);
                            mappedValue = isEndOfWord ? 'i' : 'ee';
                        }

                        result += mappedValue;
                        
                        const isConsonant = /[\u0915-\u0939]/.test(char);
                        const isNextMatra = /[\u093E-\u094D]/.test(nextChar); 
                        const isNextNonHindi = !nextChar || isSymbolOrSpace.test(nextChar) || /[a-zA-Z0-9]/.test(nextChar);

                        if (isConsonant && !isNextMatra && !isNextNonHindi) {
                            result += "a";
                        }
                    } else {
                        result += char;
                    }
                }

                return result
                    .replace(/aa/g, 'a') 
                    .replace(/Shree/g, 'Shri')
                    .replace(/^a/g, 'A') 
                    .replace(/\s[a-z]/g, (m) => m.toUpperCase());
            }

            input.addEventListener('input', () => {
                output.innerText = convert(input.value);
            });

            copyBtn.addEventListener('click', () => {
                if (output.innerText) {
                    navigator.clipboard.writeText(output.innerText);
                    status.style.display = "inline";
                    setTimeout(() => { status.style.display = "none"; }, 2000);
                }
            });
        });
    </script>
    <script src="/assets/cookie-consent.js" async></script>
</body>
