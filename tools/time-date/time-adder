    <script>
        document.addEventListener('DOMContentLoaded', () => {
            fetch('')').then(r => r.text()).then(d => { 
                document.getElementById('header-placeholder').innerHTML = d; 
                const m = document.getElementById('mobileToggle'), n = document.getElementById('navMenu');
                if(m && n) m.onclick = () => { n.classList.toggle('active'); m.innerHTML = n.classList.contains('active') ? '&#10005;' : '&#9776;'; };
            });
            fetch('')').then(r => r.text()).then(d => { document.getElementById('footer-placeholder').innerHTML = d; });

            document.querySelectorAll('a').forEach(link => {
                const linkUrl = link.getAttribute('href');
                if (linkUrl && !linkUrl.startsWith('#') && !linkUrl.startsWith('mailto:') && !linkUrl.startsWith('javascript:')) {
                    const isInternalLink = (new URL(linkUrl, window.location.href)).origin === window.location.origin;
                    if (isInternalLink && !link.target) {
                        link.addEventListener('click', function(e) {
                            e.preventDefault(); document.body.classList.add('fade-out');
                            setTimeout(() => { window.location.href = this.href; }, 400);
                        });
                    }
                }
            });

            const startDateInput = document.getElementById('start-date');
            const btnNow = document.getElementById('btn-now');
            const btnCalc = document.getElementById('btn-calc');
            const btnReset = document.getElementById('btn-reset');
            
            const resultBox = document.getElementById('result-box');
            const resultText = document.getElementById('result-text');
            const resultSub = document.getElementById('result-sub');

            const inputs = {
                years: document.getElementById('val-years'),
                months: document.getElementById('val-months'),
                weeks: document.getElementById('val-weeks'),
                days: document.getElementById('val-days'),
                hours: document.getElementById('val-hours'),
                minutes: document.getElementById('val-minutes'),
                seconds: document.getElementById('val-seconds')
            };

            function setNow() {
                const now = new Date();
                now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
                startDateInput.value = now.toISOString().slice(0,16);
            }

            setNow();
            btnNow.addEventListener('click', setNow);

            btnCalc.addEventListener('click', () => {
                if(!startDateInput.value) {
                    alert("Please set a start date.");
                    return;
                }

                const start = new Date(startDateInput.value);
                
                const op = document.querySelector('input[name="operation"]:checked').value;
                const mult = op === 'add' ? 1 : -1;

                const y = parseInt(inputs.years.value) || 0;
                const mo = parseInt(inputs.months.value) || 0;
                const w = parseInt(inputs.weeks.value) || 0;
                const d = parseInt(inputs.days.value) || 0;
                const h = parseInt(inputs.hours.value) || 0;
                const mi = parseInt(inputs.minutes.value) || 0;
                const s = parseInt(inputs.seconds.value) || 0;

                start.setFullYear(start.getFullYear() + (y * mult));
                start.setMonth(start.getMonth() + (mo * mult));
                start.setDate(start.getDate() + ((w * 7 + d) * mult));
                start.setHours(start.getHours() + (h * mult));
                start.setMinutes(start.getMinutes() + (mi * mult));
                start.setSeconds(start.getSeconds() + (s * mult));

                const options = { 
                    weekday: 'short', 
                    year: 'numeric', 
                    month: 'short', 
                    day: 'numeric', 
                    hour: 'numeric', 
                    minute: '2-digit', 
                    second: '2-digit',
                    hour12: true 
                };
                
                resultText.textContent = start.toLocaleString('en-US', options);
                resultSub.textContent = `(${start.toString().split('(')[1] || 'Local Time'})`; 
                
                resultBox.style.display = 'block';
            });

            btnReset.addEventListener('click', () => {
                Object.values(inputs).forEach(inp => inp.value = '');
                setNow();
                resultBox.style.display = 'none';
                document.querySelector('input[value="add"]').checked = true;
            });
        });
    </script>
